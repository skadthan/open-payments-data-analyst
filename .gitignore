# Large dataset files - do not commit to git
Datasets/
data/

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local

# Raw data
raw/

# Logs — ingest.log is committed for reference, other *.log files are ignored
*.log
!ingest.log

# Chainlit runtime session data (uploaded files, transient state)
.files/

# chainlit.md is rendered from chainlit.md.template at run.py startup
# with live DuckDB COUNT(*) values. The template is the source of truth.
chainlit.md

# Auto-generated tool scaffolding — but keep the config and brand assets
.chainlit/*
!.chainlit/config.toml
!.chainlit/public
.chainlit/public/*
!.chainlit/public/branding.css
!.chainlit/public/openpayments-logo.png
!.chainlit/public/openpayments-avatar.png
.claude/
